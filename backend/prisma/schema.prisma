// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  MANAGER
  STAFF
  CUSTOMER
}

enum MetalType {
  GOLD
  SILVER
}

enum InterestType {
  MONTHLY
  ANNUAL
  DAILY
}

enum PledgeStatus {
  ACTIVE
  PART_PAID
  REDEEMED
  CANCELLED
  AUCTIONED
}

enum TransactionType {
  PART_PAYMENT
  INTEREST_PAYMENT
  PLEDGE_RETURN
  CANCELLATION
}

enum PaymentMode {
  CASH
  UPI
  BANK_TRANSFER
  CARD
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(STAFF)
  refreshToken String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  pledges      Pledge[]      @relation("CreatedPledges")
  transactions Transaction[] @relation("CreatedTransactions")
  auditLogs    AuditLog[]    @relation("PerformedAuditLogs")
  orders       Order[]

  @@map("users")
}

model Customer {
  id           String   @id @default(uuid())
  fullName     String
  phone        String   @unique
  email        String?  @unique
  address      String
  aadharNumber String?  @unique
  panNumber    String?  @unique
  photoUrl     String?
  isBlocked    Boolean  @default(false)
  blockReason  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  pledges       Pledge[]
  notifications Notification[]

  @@index([createdAt])
  @@map("customers")
}

model Company {
  id            String  @id @default(uuid())
  companyName   String
  branchName    String
  address       String
  gstNumber     String?
  licenseNumber String?
  isActive      Boolean @default(true)

  @@map("companies")
}

model MetalRate {
  id            String    @id @default(uuid())
  metalType     MetalType
  ratePerGram   Decimal   @db.Decimal(12, 2)
  effectiveDate DateTime

  @@unique([metalType, effectiveDate])
  @@map("metal_rates")
}

model Scheme {
  id                   String       @id @default(uuid())
  schemeName           String
  interestRate         Decimal      @db.Decimal(5, 2)
  interestType         InterestType
  minAmount            Decimal      @db.Decimal(12, 2)
  maxAmount            Decimal      @db.Decimal(12, 2)
  redemptionPeriodDays Int
  penaltyRate          Decimal      @db.Decimal(5, 2)
  isActive             Boolean      @default(true)

  // Relations
  pledges Pledge[]

  @@map("schemes")
}

model LoanType {
  id           String  @id @default(uuid())
  loanTypeName String
  isActive     Boolean @default(true)

  // Relations
  pledges Pledge[]

  @@map("loan_types")
}

model JewelleryType {
  id                String  @id @default(uuid())
  jewelleryTypeName String
  isActive          Boolean @default(true)

  // Relations
  pledgeItems PledgeItem[]

  @@map("jewellery_types")
}

model BankMaster {
  id            String  @id @default(uuid())
  bankName      String
  branchName    String
  accountNumber String
  ifscCode      String
  isActive      Boolean @default(true)

  @@map("bank_master")
}

model Pledge {
  id              String       @id @default(uuid())
  pledgeNumber    String       @unique
  customerId      String
  schemeId        String
  loanTypeId      String
  pledgeDate      DateTime     @default(now())
  loanAmount      Decimal      @db.Decimal(12, 2)
  interestRate    Decimal      @db.Decimal(5, 2)
  interestType    InterestType
  documentCharges Decimal      @db.Decimal(10, 2)
  status          PledgeStatus @default(ACTIVE)
  totalWeightGrams Decimal     @db.Decimal(10, 3)
  totalItems      Int
  notes           String?
  createdById     String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  customer      Customer       @relation(fields: [customerId], references: [id])
  scheme        Scheme         @relation(fields: [schemeId], references: [id])
  loanType      LoanType       @relation(fields: [loanTypeId], references: [id])
  createdBy     User           @relation("CreatedPledges", fields: [createdById], references: [id])
  items         PledgeItem[]
  transactions  Transaction[]
  notifications Notification[]

  @@index([customerId])
  @@index([status])
  @@index([pledgeDate])
  @@index([createdAt])
  @@map("pledges")
}

model PledgeItem {
  id               String @id @default(uuid())
  pledgeId         String
  jewelleryTypeId  String
  itemDescription  String
  grossWeightGrams Decimal @db.Decimal(10, 3)
  netWeightGrams   Decimal @db.Decimal(10, 3)
  purity           String
  quantity         Int
  itemValue        Decimal @db.Decimal(12, 2)

  // Relations
  pledge        Pledge        @relation(fields: [pledgeId], references: [id], onDelete: Cascade)
  jewelleryType JewelleryType @relation(fields: [jewelleryTypeId], references: [id])

  @@map("pledge_items")
}

model Transaction {
  id              String          @id @default(uuid())
  pledgeId        String
  transactionType TransactionType
  amount          Decimal         @db.Decimal(12, 2)
  paymentMode     PaymentMode
  transactionDate DateTime        @default(now())
  notes           String?
  createdById     String
  createdAt       DateTime        @default(now())

  // Relations
  pledge    Pledge @relation(fields: [pledgeId], references: [id])
  createdBy User   @relation("CreatedTransactions", fields: [createdById], references: [id])

  @@index([pledgeId])
  @@index([createdAt])
  @@map("transactions")
}

model AuditLog {
  id            String      @id @default(uuid())
  tableName     String
  recordId      String
  action        AuditAction
  oldValues     Json?
  newValues     Json?
  performedById String
  performedAt   DateTime    @default(now())

  // Relations
  performedBy User @relation("PerformedAuditLogs", fields: [performedById], references: [id])

  @@index([tableName, recordId])
  @@index([performedAt])
  @@map("audit_logs")
}

model Notification {
  id         String   @id @default(uuid())
  customerId String
  type       String
  title      String
  message    String
  isRead     Boolean  @default(false)
  pledgeId   String?
  createdAt  DateTime @default(now())

  // Relations
  customer Customer @relation(fields: [customerId], references: [id])
  pledge   Pledge?  @relation(fields: [pledgeId], references: [id])

  @@index([customerId])
  @@index([createdAt])
  @@map("notifications")
}

model JewelryItem {
  id             String   @id @default(uuid())
  name           String
  description    String
  price          Decimal  @db.Decimal(12, 2)
  category       String
  imageUrl       String?
  metalType      MetalType
  weightGrams    Decimal  @db.Decimal(10, 3)
  wastagePercent Decimal  @db.Decimal(5, 2)
  stock          Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  orderItems OrderItem[]

  @@map("jewelry_items")
}

model Order {
  id              String   @id @default(uuid())
  userId          String
  totalAmount     Decimal  @db.Decimal(12, 2)
  status          String   @default("PENDING")
  paymentIntentId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  user  User        @relation(fields: [userId], references: [id])
  items OrderItem[]

  @@index([userId])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id              String  @id @default(uuid())
  orderId         String
  jewelryItemId   String
  quantity        Int
  priceAtPurchase Decimal @db.Decimal(12, 2)

  // Relations
  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  jewelryItem JewelryItem @relation(fields: [jewelryItemId], references: [id])

  @@map("order_items")
}
