# Server Configuration
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Database Configuration (Supabase + PgBouncer)
DATABASE_URL="postgresql://user:password@db_host:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:password@db_host:5432/postgres"

# Cache Configuration
REDIS_URL="redis://:password@localhost:6379"

# Security (JWT RS256)
# Generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Payments (Stripe)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email (Resend)
RESEND_API_KEY=re_...

# SMS (Twilio)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# External Data
GOLD_API_KEY=...

# Monitoring
SENTRY_DSN=https://...
